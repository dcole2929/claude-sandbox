#!/bin/bash
set -euo pipefail

SANDBOX_IMAGE="claude-sandbox-base"

# ── Usage ─────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
Usage: claude-sandbox [options] [path]

Spin up an isolated dev container with Claude Code and Docker CLI installed.
If the target directory has a docker-compose.yml, its services are started
and reachable from inside the sandbox by service name.

Arguments:
  path                Project directory to mount (default: current dir)

Options:
  -a, --account NAME    Claude account: "personal" or "work" (default: personal)
  --claude-config PATH  Path to host .claude.json (default: ~/.claude.json)
  -c, --compose FILE    Compose file to extend (default: auto-detected)
  --no-compose          Skip project compose file (sandbox only, no services)
  -n, --name NAME       Container name (default: sandbox-<dirname>)
  --memory LIMIT        Memory limit (default: 8g)
  --cpus LIMIT          CPU limit (default: 4)
  --build               Force rebuild the base image
  -h, --help            Show this help

Persistent defaults live in ~/.claude-sandbox/ (auto-created on first run)
and can be overridden per-project via <project>/.claude-sandbox/. Recognized
files: config.json (keys: claudeConfig, account, memory, cpus), bashrc
(sourced in sandbox shell), tmux.conf (mounted as ~/.tmux.conf). Project
values override user values; CLI flags override both.

Examples:
  claude-sandbox                          # current dir, personal account
  claude-sandbox ~/dev/my-api             # specific project
  claude-sandbox -a work ~/dev/project    # work Claude account
  claude-sandbox -c compose.dev.yml .     # custom compose file
  claude-sandbox --no-compose ~/dev/app   # skip broken compose file
  claude-sandbox --build                  # rebuild base image
EOF
  exit 0
}

# ── Resolve script location (follows symlinks) ───────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
SANDBOX_HOME="$(dirname "$SCRIPT_DIR")"

# ── Built-in defaults ─────────────────────────────────────────
ACCOUNT="personal"
COMPOSE_FILE=""
NO_COMPOSE=false
CONTAINER_NAME=""
MEMORY="8g"
CPUS="4"
FORCE_BUILD=false
PROJECT_DIR=""
CLAUDE_CONFIG_PATH=""

# CLI buffers for settings that layer over config files (empty = not set)
CLI_ACCOUNT=""
CLI_CLAUDE_CONFIG=""
CLI_MEMORY=""
CLI_CPUS=""

# ── Parse CLI args ────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -a|--account)     CLI_ACCOUNT="$2"; shift 2 ;;
    --claude-config)  CLI_CLAUDE_CONFIG="$2"; shift 2 ;;
    -c|--compose)     COMPOSE_FILE="$2"; shift 2 ;;
    --no-compose)     NO_COMPOSE=true; shift ;;
    -n|--name)        CONTAINER_NAME="$2"; shift 2 ;;
    --memory)         CLI_MEMORY="$2"; shift 2 ;;
    --cpus)           CLI_CPUS="$2"; shift 2 ;;
    --build)          FORCE_BUILD=true; shift ;;
    -h|--help)        usage ;;
    -*)               echo "Unknown option: $1"; usage ;;
    *)                PROJECT_DIR="$1"; shift ;;
  esac
done

PROJECT_DIR="$(cd "${PROJECT_DIR:-.}" && pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

# ── Auto-create user sandbox config on first run ──────────────
USER_SANDBOX_DIR="$HOME/.claude-sandbox"
if [[ ! -f "$USER_SANDBOX_DIR/config.json" ]]; then
  mkdir -p "$USER_SANDBOX_DIR"
  cat > "$USER_SANDBOX_DIR/config.json" <<'JSON'
{
  "account": "personal",
  "memory": "8g",
  "cpus": "4"
}
JSON
  echo "Wrote default config to $USER_SANDBOX_DIR/config.json"
fi

# ── Layer configs: defaults → user → project → CLI ────────────
PROJECT_SANDBOX_DIR="$PROJECT_DIR/.claude-sandbox"

read_sandbox_cfg() {
  # $1 = file, $2 = key
  python3 - "$1" "$2" <<'PY' 2>/dev/null
import json, sys
try:
    with open(sys.argv[1]) as f:
        d = json.load(f)
    v = d.get(sys.argv[2], "")
    if v:
        print(v, end="")
except Exception:
    pass
PY
}

load_config_file() {
  local path="$1"
  [[ -f "$path" ]] || return 0
  if ! command -v python3 &>/dev/null; then
    echo "Warning: $path exists but python3 is unavailable — skipping"
    return 0
  fi
  local v
  v="$(read_sandbox_cfg "$path" claudeConfig)"; [[ -n "$v" ]] && CLAUDE_CONFIG_PATH="$v"
  v="$(read_sandbox_cfg "$path" account)";      [[ -n "$v" ]] && ACCOUNT="$v"
  v="$(read_sandbox_cfg "$path" memory)";       [[ -n "$v" ]] && MEMORY="$v"
  v="$(read_sandbox_cfg "$path" cpus)";         [[ -n "$v" ]] && CPUS="$v"
}

load_config_file "$USER_SANDBOX_DIR/config.json"
load_config_file "$PROJECT_SANDBOX_DIR/config.json"

# Apply CLI overrides last
[[ -n "$CLI_ACCOUNT"       ]] && ACCOUNT="$CLI_ACCOUNT"
[[ -n "$CLI_CLAUDE_CONFIG" ]] && CLAUDE_CONFIG_PATH="$CLI_CLAUDE_CONFIG"
[[ -n "$CLI_MEMORY"        ]] && MEMORY="$CLI_MEMORY"
[[ -n "$CLI_CPUS"          ]] && CPUS="$CLI_CPUS"

CONTAINER_NAME="${CONTAINER_NAME:-sandbox-${PROJECT_NAME}}"

# ── Resolve Claude config paths ───────────────────────────────
case "$ACCOUNT" in
  work)     CLAUDE_DIR="$HOME/.claude-work" ;;
  personal) CLAUDE_DIR="$HOME/.claude" ;;
  *)        echo "Error: Unknown account '$ACCOUNT' (use 'personal' or 'work')"; exit 1 ;;
esac

if [[ ! -d "$CLAUDE_DIR" ]]; then
  echo "Error: Claude data dir not found at $CLAUDE_DIR"
  exit 1
fi

# Resolve main Claude config file path.
# Priority:
#   1. Explicit --claude-config (CLI or config.json): mount that file over the default.
#   2. Inside the data dir ($CLAUDE_DIR/.claude.json): preferred on modern Linux/WSL —
#      already available via the $CLAUDE_DIR bind mount, no extra mount needed.
#   3. Legacy sibling ($HOME/.claude.json or $HOME/.claude-work.json): macOS layout.
#      Mount it over the nested path so Claude sees it as its config.
CLAUDE_JSON_VOLUME=""

if [[ -n "$CLAUDE_CONFIG_PATH" ]]; then
  # User explicitly specified a path
  if [[ -f "$CLAUDE_CONFIG_PATH" ]]; then
    CLAUDE_JSON_VOLUME="      - ${CLAUDE_CONFIG_PATH}:/home/dev/.claude/.claude.json"$'\n'
  else
    echo "Warning: Claude config file not found at $CLAUDE_CONFIG_PATH — container will start without saved identity"
  fi
elif [[ -f "$CLAUDE_DIR/.claude.json" ]]; then
  # Canonical location inside the data dir; already mounted via $CLAUDE_DIR
  CLAUDE_CONFIG_PATH="$CLAUDE_DIR/.claude.json"
else
  # Legacy sibling path (macOS)
  case "$ACCOUNT" in
    work)     CLAUDE_CONFIG_PATH="$HOME/.claude-work.json" ;;
    personal) CLAUDE_CONFIG_PATH="$HOME/.claude.json" ;;
  esac
  if [[ -f "$CLAUDE_CONFIG_PATH" ]]; then
    CLAUDE_JSON_VOLUME="      - ${CLAUDE_CONFIG_PATH}:/home/dev/.claude/.claude.json"$'\n'
  else
    echo "Warning: Claude config file not found at $CLAUDE_CONFIG_PATH — container will start without saved identity"
  fi
fi

# ── Extract OAuth credentials from macOS Keychain ─────────────
CREDS_TEMP=""
CREDS_VOLUME=""
if command -v security &>/dev/null; then
  CREDS_JSON="$(security find-generic-password -s 'Claude Code-credentials' -w 2>/dev/null || true)"
  if [[ -n "$CREDS_JSON" ]]; then
    CREDS_TEMP=$(mktemp /tmp/claude-sandbox-creds-XXXX.json)
    chmod 600 "$CREDS_TEMP"
    printf '%s' "$CREDS_JSON" > "$CREDS_TEMP"
    CREDS_VOLUME="      - ${CREDS_TEMP}:/home/dev/.claude/.credentials.json"$'\n'
  fi
fi

# ── Concat layered dotfiles (user → project) into tempfiles ──
build_layered_tempfile() {
  # $1 = output var name, $2 = volume var name, $3 = container target, rest = candidate paths
  local out_var="$1" vol_var="$2" target="$3"; shift 3
  local files=()
  for f in "$@"; do [[ -f "$f" ]] && files+=("$f"); done
  if [[ ${#files[@]} -gt 0 ]]; then
    local tmp
    tmp=$(mktemp "/tmp/claude-sandbox-$(basename "$target")-XXXX")
    cat "${files[@]}" > "$tmp"
    printf -v "$out_var" '%s' "$tmp"
    printf -v "$vol_var" '      - %s:%s:ro\n' "$tmp" "$target"
  fi
}

BASHRC_TEMP=""; BASHRC_VOLUME=""
build_layered_tempfile BASHRC_TEMP BASHRC_VOLUME /home/dev/.sandbox-rc \
  "$USER_SANDBOX_DIR/bashrc" "$PROJECT_SANDBOX_DIR/bashrc"

TMUX_TEMP=""; TMUX_VOLUME=""
build_layered_tempfile TMUX_TEMP TMUX_VOLUME /home/dev/.tmux.conf \
  "$USER_SANDBOX_DIR/tmux.conf" "$PROJECT_SANDBOX_DIR/tmux.conf"

# ── Resolve git/GitHub config paths ───────────────────────────
GH_CONFIG_DIR="${GH_CONFIG_DIR:-$HOME/.config/gh}"

GITCONFIG_VOLUME=""
GH_VOLUME=""
[[ -f "$HOME/.gitconfig" ]] && GITCONFIG_VOLUME="      - ${HOME}/.gitconfig:/home/dev/.gitconfig.host:ro"$'\n'
[[ -d "$GH_CONFIG_DIR" ]]   && GH_VOLUME="      - ${GH_CONFIG_DIR}:/home/dev/.config/gh"$'\n'

# ── Ensure base image exists ──────────────────────────────────
if $FORCE_BUILD || ! docker image inspect "$SANDBOX_IMAGE" &>/dev/null; then
  echo "Building base sandbox image..."
  docker build -t "$SANDBOX_IMAGE" "$SANDBOX_HOME/base"
fi

# ── Auto-detect project compose file ─────────────────────────
if ! $NO_COMPOSE && [[ -z "$COMPOSE_FILE" ]]; then
  for candidate in \
    "$PROJECT_DIR/docker-compose.yml" \
    "$PROJECT_DIR/docker-compose.yaml" \
    "$PROJECT_DIR/compose.yml" \
    "$PROJECT_DIR/compose.yaml"; do
    if [[ -f "$candidate" ]]; then
      COMPOSE_FILE="$candidate"
      break
    fi
  done
fi

if $NO_COMPOSE; then
  COMPOSE_FILE=""
fi

# ── Generate sandbox overlay ─────────────────────────────────
OVERLAY_FILE=$(mktemp /tmp/claude-sandbox-XXXX.yml)
cleanup() {
  rm -f "$OVERLAY_FILE"
  [[ -n "$CREDS_TEMP"  ]] && rm -f "$CREDS_TEMP"
  [[ -n "$BASHRC_TEMP" ]] && rm -f "$BASHRC_TEMP"
  [[ -n "$TMUX_TEMP"   ]] && rm -f "$TMUX_TEMP"
}
trap cleanup EXIT

# If project has a compose file, wire up depends_on
DEPENDS_ON=""
if [[ -n "$COMPOSE_FILE" ]]; then
  SVC_NAMES=$(docker compose -f "$COMPOSE_FILE" config --services 2>/dev/null || true)
  if [[ -n "$SVC_NAMES" ]]; then
    DEPENDS_ON="    depends_on:"$'\n'
    while IFS= read -r svc; do
      DEPENDS_ON+="      ${svc}:"$'\n'
      DEPENDS_ON+="        condition: service_started"$'\n'
    done <<< "$SVC_NAMES"
  fi
fi

cat > "$OVERLAY_FILE" <<YAML
services:
  sandbox:
    image: ${SANDBOX_IMAGE}
    container_name: ${CONTAINER_NAME}
    hostname: sandbox
    extra_hosts:
      - "sandbox:127.0.0.1"
    network_mode: host
    stdin_open: true
    tty: true
    working_dir: ${PROJECT_DIR}
    environment:
      - CLAUDE_CONFIG_DIR=/home/dev/.claude
    volumes:
      - ${PROJECT_DIR}:${PROJECT_DIR}
      - ${CLAUDE_DIR}:/home/dev/.claude
      - /var/run/docker.sock:/var/run/docker.sock
${CLAUDE_JSON_VOLUME}${CREDS_VOLUME}${BASHRC_VOLUME}${TMUX_VOLUME}${GITCONFIG_VOLUME}${GH_VOLUME}
    mem_limit: ${MEMORY}
    cpus: ${CPUS}
${DEPENDS_ON}
YAML

# ── Build compose command ─────────────────────────────────────
COMPOSE_CMD=(docker compose -p "$CONTAINER_NAME")

if [[ -n "$COMPOSE_FILE" ]]; then
  COMPOSE_CMD+=(-f "$COMPOSE_FILE")
fi
COMPOSE_CMD+=(-f "$OVERLAY_FILE")

# ── Launch ────────────────────────────────────────────────────
echo "Project:   $PROJECT_DIR"
echo "Account:   $ACCOUNT"
echo "Config:    ${CLAUDE_CONFIG_PATH:-<none>}$([[ -z "$CLAUDE_JSON_VOLUME" ]] && echo ' (missing)')"
echo "Creds:     $([[ -n "$CREDS_TEMP" ]] && echo 'Keychain' || echo '<none — login required>')"
if [[ -n "$COMPOSE_FILE" ]]; then
  echo "Compose:   $COMPOSE_FILE"
  echo "Services:  $(echo "$SVC_NAMES" | tr '\n' ' ')"
fi
echo "Network:   host"
echo "Container: $CONTAINER_NAME"
echo "---"

"${COMPOSE_CMD[@]}" run --rm sandbox

# Cleanup services on exit
"${COMPOSE_CMD[@]}" down 2>/dev/null
